# YouTube: official Data API (optional if you use yt-dlp below)
YOUTUBE_API_KEY=

# Innertube search via yt-dlp — no API key; default true (set false to disable)
YOUTUBE_USE_YTDLP=true

# DuckDuckGo site: search for TikTok / Facebook / Instagram (no Google API). Default on.
DDG_SOCIAL_ENABLED=true

# Brave Search API — optional fourth fallback after native + DDG (set enabled + key).
BRAVE_SEARCH_ENABLED=false
BRAVE_SEARCH_API_KEY=

# Google Programmable Search — off by default. Set true + keys only if you want CSE for TT/FB/IG.
GOOGLE_CSE_ENABLED=false
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# Direct TikTok / Instagram (defaults on; install: pip install -e ".[direct]" && playwright install chromium)
TIKTOK_DIRECT_ENABLED=true
TIKTOK_MS_TOKEN=
TIKTOK_BROWSER=chromium

INSTAGRAM_DIRECT_ENABLED=true
# Optional session file from instaloader for hashtag access
INSTAGRAM_SESSION_FILE=

# Next.js / web UI: run Python TikTok direct via subprocess (same as CLI). Default on; set false to skip.
TIKTOK_DIRECT_PYTHON=true

# Legacy early SKU filter (off by default in Python / web unless set true).
STRICT_SKU_FILTER=false

# Optional: smarter query phrases + optional relevance scoring (free tier on Groq)
GROQ_API_KEY=

# Reddit requires a descriptive User-Agent (set your contact if you use this in production)
REDDIT_USER_AGENT=SocialMediaLinkCollector/1.0 (Contact: you@example.com)

# Defaults (optional)
MAX_RESULTS_PER_PLATFORM=5
REQUEST_TIMEOUT_SECONDS=30
GROQ_MODEL=llama-3.3-70b-versatile
