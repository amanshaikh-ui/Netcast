# Copy to .env.local — never commit .env.local
# Same variables as the Python CLI (project root .env)
#
# Vercel: Project → Settings → Environment Variables — paste the same keys.
# On Vercel (VERCEL=1), TikTok Python is off unless TIKTOK_DIRECT_PYTHON=true.
# TikTok still uses DDG/CSE when enabled.

YOUTUBE_API_KEY=
# yt-dlp Innertube search (install yt-dlp or Python yt_dlp); optional YTDLP_BIN
YOUTUBE_USE_YTDLP=true
DDG_SOCIAL_ENABLED=true
# CSE off by default; set true only with GOOGLE_CSE_API_KEY + GOOGLE_CSE_ID
GOOGLE_CSE_ENABLED=false
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
GROQ_API_KEY=

# Python TikTok subprocess: same venv as `pip install -e ".[direct]"` + `playwright install chromium` from repo root.
# If `python` on PATH is wrong, set e.g. PYTHON_BIN=C:\path\to\link search\.venv\Scripts\python.exe (quotes not needed in .env)
PYTHON_BIN=
TIKTOK_DIRECT_PYTHON=true
STRICT_SKU_FILTER=true

REDDIT_USER_AGENT=SocialMediaLinkCollector/1.0 (Contact: you@example.com)

MAX_RESULTS_PER_PLATFORM=5
REQUEST_TIMEOUT_SECONDS=30
GROQ_MODEL=llama-3.3-70b-versatile
